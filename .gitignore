# --- Compiled output ---
*.class
/PRG381Group4/build/
/PRG381Group4/dist/

# --- NetBeans per-user settings (must never be shared) ---
/PRG381Group4/nbproject/private/

# --- Apache Derby database ---
# Derby creates this folder at runtime. NEVER commit it: it is binary, it
# changes on every run, and it will cause merge conflicts on every push.
/PRG381Group4/cleaninvdb/
derby.log

# --- Jars ---
# Ignore jars in general, BUT keep the Derby jars, because the project will not
# run without them and this is how every team member gets them.
*.jar
!PRG381Group4/lib/*.jar

*.war
*.ear
*.log
*.ctxt
hs_err_pid*
replay_pid*
